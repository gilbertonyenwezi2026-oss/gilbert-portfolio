    <item>
      <title>Go &#43; Hugo Portfolio Website</title>
      <link>http://localhost:1313/projects_backup/go-hugo-portfolio/</link>
      <pubDate>Wed, 08 Apr 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/projects_backup/go-hugo-portfolio/</guid>
      <description>&lt;h2 id=&#34;objective&#34;&gt;Objective&lt;/h2&gt;&#xA;&lt;p&gt;Build a fast, scalable personal website using Hugo to showcase technical projects and professional experience.&lt;/p&gt;&#xA;&lt;h2 id=&#34;tools&#34;&gt;Tools&lt;/h2&gt;&#xA;&lt;p&gt;Go, Hugo, Git, GitHub, Netlify&lt;/p&gt;</description>
